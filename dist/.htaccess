# Lives in the dist docroot (uzair.nexteksol.com points here). Same SPA + same-origin
# proxy pattern as the other portfolio frontends, pointed at Uzair's backend
# container (shared engine on the dev-uzair branch) running on localhost:8002.
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# API + health -> Uzair's backend container on localhost:8002 (same origin: no CORS, no mixed content)
RewriteRule ^(ask|health|docs|openapi\.json)(.*)$ http://localhost:8002/$1$2 [P,L]

# SPA client-side routing: real files served as-is, everything else -> index.html
RewriteRule ^index\.html$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]
</IfModule>

# Cache contract so deploys never need a manual purge:
#  - index.html: always revalidate (picks up new asset hashes immediately)
#  - hashed assets: cache forever (safe - a new build changes the filename)
<IfModule mod_headers.c>
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(js|css|svg|png|jpe?g|webp|woff2?|ttf|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
